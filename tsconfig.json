{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx"
  },
  "include": [
    "schemas",
    "repositories",
    "lib",
    "api",
    "types",
    "pages",
    "components",
    "hooks",
    "index.ts",
    "server.ts",
    "register.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
